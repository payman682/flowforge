<odoo>
    <record id="view_flowforge_template_list" model="ir.ui.view">
        <field name="name">flowforge.approval.template.list</field>
        <field name="model">flowforge.approval.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_flowforge_template_form" model="ir.ui.view">
        <field name="name">flowforge.approval.template.form</field>
        <field name="model">flowforge.approval.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="active"/>
                    </group>
                    <field name="note"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_flowforge_templates" model="ir.actions.act_window">
        <field name="name">Templates</field>
        <field name="res_model">flowforge.approval.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
