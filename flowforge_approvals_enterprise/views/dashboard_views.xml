<odoo>
    <record id="view_flowforge_dashboard_form" model="ir.ui.view">
        <field name="name">flowforge.approval.dashboard.form</field>
        <field name="model">flowforge.approval.dashboard</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <group col="4">
                        <group><field name="pending_count" readonly="1"/></group>
                        <group><field name="approved_count" readonly="1"/></group>
                        <group><field name="rejected_count" readonly="1"/></group>
                        <group><field name="overdue_count" readonly="1"/></group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_flowforge_dashboard" model="ir.actions.act_window">
        <field name="name">Approval Dashboard</field>
        <field name="res_model">flowforge.approval.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
</odoo>
