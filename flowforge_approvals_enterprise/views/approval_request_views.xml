<odoo>
    <record id="view_flowforge_request_list" model="ir.ui.view">
        <field name="name">flowforge.approval.request.list</field>
        <field name="model">flowforge.approval.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="target_display_name"/>
                <field name="rule_id"/>
                <field name="requested_by_id"/>
                <field name="state" widget="badge"/>
                <field name="current_level"/>
                <field name="due_date"/>
            </list>
        </field>
    </record>

    <record id="view_flowforge_request_form" model="ir.ui.view">
        <field name="name">flowforge.approval.request.form</field>
        <field name="model">flowforge.approval.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="not can_current_user_approve or state != 'pending'"/>
                    <button name="action_reject" string="Reject" type="object" invisible="not can_current_user_approve or state != 'pending'"/>
                    <button name="action_request_changes" string="Request Changes" type="object" invisible="not can_current_user_approve or state != 'pending'"/>
                    <button name="action_resubmit" string="Resubmit" type="object" invisible="state != 'changes_requested'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft','pending','changes_requested')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved,rejected,changes_requested,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="rule_id"/>
                            <field name="requested_by_id"/>
                            <field name="current_level"/>
                        </group>
                        <group>
                            <field name="res_ref"/>
                            <field name="target_display_name" readonly="1"/>
                            <field name="due_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Approvers">
                            <field name="line_ids">
                                <list>
                                    <field name="sequence"/>
                                    <field name="stage_id"/>
                                    <field name="user_id"/>
                                    <field name="state" widget="badge"/>
                                    <field name="deadline"/>
                                    <field name="action_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Logs">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="action"/>
                                    <field name="user_id"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_flowforge_requests" model="ir.actions.act_window">
        <field name="name">Approval Requests</field>
        <field name="res_model">flowforge.approval.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
