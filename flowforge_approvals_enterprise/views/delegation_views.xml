<odoo>
    <record id="view_flowforge_delegation_list" model="ir.ui.view">
        <field name="name">flowforge.approval.delegation.list</field>
        <field name="model">flowforge.approval.delegation</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="delegate_user_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_flowforge_delegation_form" model="ir.ui.view">
        <field name="name">flowforge.approval.delegation.form</field>
        <field name="model">flowforge.approval.delegation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="delegate_user_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="active"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_flowforge_delegations" model="ir.actions.act_window">
        <field name="name">Delegations</field>
        <field name="res_model">flowforge.approval.delegation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
